generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GOOGLE
  PHANTOM
}

enum MatchStatus {
  COMPLETED
  ABORTED
}

enum RewardStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  username       String?        @unique
  usernameNormalized String?    @unique
  avatarUrl      String?
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       AuthAccount[]
  sessions       AuthSession[]
  wonMatches     Match[]        @relation("MatchWinner")
  matchPlayers   MatchPlayer[]
  rewards        RewardLog[]
  settings       UserSetting[]
}

model AuthAccount {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @db.Uuid
  provider           AuthProvider
  providerAccountId  String
  email              String?
  walletAddress      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([provider, email])
  @@unique([provider, walletAddress])
  @@index([userId])
}

model WalletNonce {
  id            String    @id @default(uuid()) @db.Uuid
  walletAddress String
  nonceHash     String    @unique
  message       String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([walletAddress, expiresAt])
}

model AuthSession {
  id         String    @id @db.Uuid
  userId     String    @db.Uuid
  provider   AuthProvider
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model UserSetting {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  key       String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Match {
  id              String         @id @default(uuid()) @db.Uuid
  roomId          String         @unique
  mapName         String?
  status          MatchStatus    @default(COMPLETED)
  winnerUserId    String?        @db.Uuid
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  createdAt       DateTime       @default(now())
  winner          User?          @relation("MatchWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  players         MatchPlayer[]
  rewards         RewardLog[]
}

model MatchPlayer {
  id           String   @id @default(uuid()) @db.Uuid
  matchId      String   @db.Uuid
  userId       String   @db.Uuid
  placement    Int
  kills        Int      @default(0)
  deaths       Int      @default(0)
  damageDealt  Int      @default(0)
  damageTaken  Int      @default(0)
  winner       Boolean  @default(false)
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, userId])
  @@index([userId])
}

model RewardLog {
  id            String       @id @default(uuid()) @db.Uuid
  matchId       String       @db.Uuid
  userId        String       @db.Uuid
  walletAddress String
  amount        Decimal      @db.Decimal(20, 8)
  asset         String
  status        RewardStatus @default(PENDING)
  transactionId String?
  errorMessage  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  match         Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, userId])
  @@index([status])
}
